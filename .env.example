# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored by Vite convention so your keys stay private.

VITE_SUPABASE_URL=https://your_project_id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Use a public URL that is valid for both web and APK OAuth callbacks.
# Example: https://app.seudominio.com or your stable tunnel URL for testing.
VITE_AUTH_REDIRECT_URL=https://your-public-app-url

# Brandfetch — required for logo lookup
# VITE_BRANDFETCH_API_KEY:   REST API key used for the Search API (domain resolution)
# VITE_BRANDFETCH_CLIENT_ID: Client ID used for CDN logo image requests
VITE_BRANDFETCH_API_KEY=your_brandfetch_api_key
VITE_BRANDFETCH_CLIENT_ID=your_brandfetch_client_id
